{% assign wl = trmnl.plugin_settings.custom_fields_values.wl_lines | default: "" %}
{% assign monitored_lines = wl | remove: " " | split: "," %}

{% capture keys -%}
{%- for t in data.trafficInfos -%}
  {%- if t.status == "active" -%}
    {%- if t.time and t.time.start -%}{{ t.time.start }}{%- else -%}0000-00-00T00:00:00.000+0000{%- endif -%}|{{ t.name }}||
  {%- endif -%}
{%- endfor -%}
{%- endcapture %}
{%- assign keys = keys | split: "||" | sort | reverse -%}

{% capture any_flag -%}
{%- for t in data.trafficInfos -%}
  {%- if t.status == "active" -%}
    {%- for line in t.relatedLines -%}
      {%- if monitored_lines contains line -%}1{%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}
{%- endcapture %}
{% assign any_flag = any_flag | strip %}
